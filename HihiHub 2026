rs.RenderStepped:Connect(function()
        for plr, esptab in pairs(EspTable) do
                local enemychar = plr.Character
                local enemyhum = enemychar and enemychar:FindFirstChild("Humanoid")
                local enemyhrp = enemychar and enemychar:FindFirstChild("HumanoidRootPart")
                local enemyhead = enemychar and enemychar:FindFirstChild("Head")
                if enemychar and enemyhum and enemyhum.Health > 0 and enemyhrp and config.Esp == true  then 
               
                    local hrpPos, onscreen = lcamera:WorldToViewportPoint(enemyhrp.Position)
                    local headPos = lcamera:WorldToViewportPoint(enemyhead.Position)
                    local TopPos = lcamera:WorldToViewportPoint(enemyhrp.Position + Vector3.new(0,3,0))
                    local BotPos = lcamera:WorldToViewportPoint(enemyhrp.Position - Vector3.new(0,3,0))

                    local BoxY = math.abs(TopPos.Y - BotPos.Y)
                    local BoxX = BoxY / 2


                    if onscreen then
                        if config.HealthEsp == true then
                            local boxPos = Vector2.new(hrpPos.X - BoxX / 2, hrpPos.Y - BoxY / 2)

                            local health = enemyhum.Health
                            local maxHealth = enemyhum.MaxHealth
                            local healthPercent = math.clamp(health / maxHealth, 0, 1)
                                esptab.healthbar.Visible = true
                                esptab.healthoutline.Visible = true

                                esptab.healthoutline.Size = Vector2.new(3, BoxY)
                                esptab.healthoutline.Position = Vector2.new(boxPos.X - 6, boxPos.Y)
                        
                                esptab.healthbar.Size = Vector2.new(2, BoxY * healthPercent)
                                esptab.healthbar.Position = Vector2.new(boxPos.X - 5,boxPos.Y + (BoxY - (BoxY * healthPercent)))
                        else
                                esptab.healthbar.Visible = false
                                esptab.healthoutline.Visible = false
                        end

                        if config.Tracer == true then
                                esptab.Tracer.From = Vector2.new(lcamera.ViewportSize.X / 2, 0)
                                esptab.Tracer.To = Vector2.new(headPos.X, headPos.Y)
                                esptab.Tracer.Color = config.EspColor
                                esptab.Tracer.Visible = true
                                
                        else
                                esptab.Tracer.Visible = false
                        end

                        if config.NameEsp==true then
                            esptab.Name.Text = plr.Name
                            esptab.Name.Position  = Vector2.new(hrpPos.X, hrpPos.Y - BoxY/2 - 15)
                            esptab.Name.Visible = true 
                        else
                            esptab.Name.Visible = false
                        end

                        esptab.box.Size = Vector2.new(BoxX, BoxY)
                        esptab.box.Position = Vector2.new(hrpPos.X - BoxX / 2, hrpPos.Y - BoxY / 2)
                        esptab.box.Color = config.EspColor
                        esptab.box.Visible = true
                    else
                            esptab.box.Visible = false
                            esptab.healthbar.Visible = false
                            esptab.healthoutline.Visible = false
                            esptab.Tracer.Visible = false
                            esptab.Name.Visible = false
                    end
                else
                    esptab.box.Visible = false
                    esptab.healthbar.Visible = false
                    esptab.healthoutline.Visible = false
                    esptab.Tracer.Visible = false
                    esptab.Name.Visible = false
                end
        end
end)




