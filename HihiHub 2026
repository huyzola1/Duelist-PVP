local Workspace = game:GetService("Workspace")
local function IsVisible(targetPart)
    if config.IgnoreWall then
        return true
    end

    local origin = workspace.CurrentCamera.CFrame.Position
    local direction = targetPart.Position - origin

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {
        game.Players.LocalPlayer.Character
    }

    local result = Workspace:Raycast(origin, direction, params)

    if not result then
        return true
    end

    return result.Instance:IsDescendantOf(targetPart.Parent)
end

Rs.RenderStepped:Connect(function()
    if config.Aimbot == true then
        local distance = math.huge
        local closetChar = nil

        for __, target in pairs(Plrs:GetChildren()) do
            if target ~= lplr  and target.Character then
                local char = target.Character
                if config.Aimbot == true then
                                local char = target.Character
                                if IsVisible(char[config.AimPart]) then
                                    local targetPart = char:FindFirstChild(config.AimPart)
                                    if targetPart and IsVisible(targetPart) then
                                            local TargetPartPos, is_os = lcamera:WorldToViewportPoint(targetPart.Position)
                                            if is_os and char:FindFirstChild("Humanoid").Health > 0 then



                                                local mag = (Vector2.new(lcamera.ViewportSize.X /2, lcamera.ViewportSize.Y / 2) - Vector2.new(TargetPartPos.X, TargetPartPos.Y)).Magnitude

                                                if mag < distance and mag < config.fov_radius  then
                                                    distance = mag
                                                    closetChar = char
                                                end
                                            end
                                    end
                                end

                                
                end
            end
        end

        local Humanoid = closetChar:FindFirstChild("Humanoid")

        if closetChar ~= nil  and  Humanoid and Humanoid.Health > 0 and config.Aiming == true then
            lcamera.CFrame = CFrame.new(lcamera.CFrame.Position, closetChar[config.AimPart].Position)
        end

        end
end)

