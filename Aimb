local EspTable = {}


local function CreatEsp(plr)
    if EspTable[plr] then return end
    if plr == lplr then return end

    local box = Drawing.new("Square")
    box.Color = config.EspColor
    box.Thickness = 1
    box.Filled = false
    box.Visible = false


    local healthOL = Drawing.new("Square")
    healthOL.Color = Color3.fromRGB(0, 0, 0)
    healthOL.Thickness = 2
    healthOL.Filled = true
    healthOL.Visible = false

    local healthbar = Drawing.new("Square")
    healthbar.Color = Color3.fromRGB(15, 219, 93)
    healthbar.Thickness = 1
    healthbar.Filled = true
    healthbar.Visible = false

    
    local Tracer = Drawing.new("Line")
    Tracer.Color = Color3.fromRGB(201, 27, 27)
    Tracer.Thickness = 1
    Tracer.Visible = false

    local Name = Drawing.new("Text")
    Name.Size = 8
    Name.Center = true
    Name.Outline = true
    Name.Font = 1
    Name.OutlineColor = Color3.new()
    Name.Color = Color3.new(1, 1, 1)
    Name.Visible = false
    Name.Text = plr.Name


    EspTable[plr] = {box = box, healthbar = healthbar, healthoutline = healthOL, Tracer = Tracer, Name = Name} 
end

local function RemoveEsp(plr)
    if EspTable[plr] then
                    EspTable[plr].box:Remove()
                    EspTable[plr].healthbar:Remove()
                    EspTable[plr].healthoutline:Remove()
                    EspTable[plr].Tracer:Remove()
                    EspTable[plr].Name:Remove()

                    EspTable[plr] = nil
    end
end

plrs.PlayerAdded:Connect(function(plr)
        if config.Esp == true then
        CreatEsp(plr)
        end
end)

plrs.PlayerRemoving:Connect(function(plr)
    RemoveEsp(plr)
end)


